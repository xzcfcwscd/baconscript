--------------------------------------------------
-- ADD HIGHLIGHT + BOX
--------------------------------------------------
local function addHighlight(obj)
    if obj:FindFirstChild("ESP_HIGHLIGHT") then return end

    -------------------------
    -- HIGHLIGHT
    -------------------------
    local h = Instance.new("Highlight")
    h.Name = "ESP_HIGHLIGHT"
    h.FillColor = Color3.fromRGB(0, 255, 0)
    h.FillTransparency = 0.5
    h.OutlineTransparency = 1
    h.Parent = obj

    table.insert(highlights, h)

    -------------------------
    -- BOX
    -------------------------
    local adorneePart

    if obj:IsA("Model") then
        adorneePart = obj:FindFirstChildWhichIsA("BasePart")
    elseif obj:IsA("BasePart") then
        adorneePart = obj
    end

    if adorneePart then
        local box = Instance.new("BoxHandleAdornment")
        box.Name = "ESP_BOX"
        box.Adornee = adorneePart
        box.AlwaysOnTop = true
        box.ZIndex = 5
        box.Size = adorneePart.Size + Vector3.new(0.1, 0.1, 0.1)
        box.Color3 = Color3.fromRGB(0, 255, 0)
        box.Transparency = 0.3
        box.Parent = adorneePart

        table.insert(highlights, box)
    end
end

--------------------------------------------------
-- CLEAR EVERYTHING
--------------------------------------------------
local function clearAll()
    for _, h in ipairs(highlights) do
        if h then h:Destroy() end
    end
    highlights = {}

    for _, c in ipairs(connections) do
        c:Disconnect()
    end
    connections = {}
end

--------------------------------------------------
-- PATHSTANDS
--------------------------------------------------
local function setupPathStands(path)
    for _, obj in ipairs(path:GetChildren()) do
        if obj:IsA("Model") then
            addHighlight(obj)
        end
    end

    table.insert(connections, path.ChildAdded:Connect(function(obj)
        if enabled and obj:IsA("Model") then
            addHighlight(obj)
        end
    end))
end

--------------------------------------------------
-- DEFAULT PARTS
--------------------------------------------------
local function setupDefaults()
    for _, obj in ipairs(workspace:GetDescendants()) do
        if obj:IsA("BasePart") and obj.Name == "Default" then
            addHighlight(obj)
        end
    end

    table.insert(connections, workspace.DescendantAdded:Connect(function(obj)
        if enabled and obj:IsA("BasePart") and obj.Name == "Default" then
            addHighlight(obj)
        end
    end))
end

--------------------------------------------------
-- WORKSPACE.PATH
--------------------------------------------------
local function setupPath(pathFolder)
    for _, obj in ipairs(pathFolder:GetDescendants()) do
        if obj:IsA("Model") or obj:IsA("BasePart") then
            addHighlight(obj)
        end
    end

    table.insert(connections, pathFolder.DescendantAdded:Connect(function(obj)
        if enabled and (obj:IsA("Model") or obj:IsA("BasePart")) then
            addHighlight(obj)
        end
    end))
end

